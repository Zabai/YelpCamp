<% include ../partials/header.ejs %>

<div class="container">
    <div class="row">
        <h1 style="text-align: center;">Edit comment</h1>

        <div style="width: 30%; margin: 25px auto;">
            <form action="/campgrounds/<%= campgroundId %>/comments/<%= comment._id %>?_method=PUT" method="post">
                <div class="form-group">
                    <input type="text" name="comment[text]" placeholder="Comment" value="<%= comment.text %>"
                           class="form-control">
                </div>
                <div class="form-group">
                    <button class="btn btn-primary btn-default btn-lg btn-block">Submit</button>
                </div>
            </form>

            <a href="/campgrounds/<%= campgroundId %>" class="btn btn-danger btn-default btn-lg btn-block">Go back</a>
        </div>
    </div>
</div>

<% include ../partials/footer.ejs %>