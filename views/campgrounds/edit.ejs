<% include ../partials/header.ejs %>

<div class="container">
    <div class="row">
        <h1 style="text-align: center;">Edit <%= campground.name %></h1>

        <div style="width: 30%; margin: 25px auto;">
            <form action="/campgrounds/<%= campground._id %>?_method=PUT" method="post">
                <div class="form-group">
                    <input type="text" name="campground[name]" placeholder="Name" value="<%= campground.name %>"
                           class="form-control">
                </div>
                <div class="form-group">
                    <input type="text" name="campground[image]" placeholder="Image URL" value="<%= campground.image %>"
                           class="form-control">
                </div>
                <div class="form-group">
                    <input type="text" name="campground[description]" placeholder="Description"
                           value="<%= campground.description %>" class="form-control">
                </div>
                <div class="form-group">
                    <button class="btn btn-primary btn-default btn-lg btn-block">Submit</button>
                </div>
            </form>

            <a href="/campgrounds" class="btn btn-danger btn-default btn-lg btn-block">Go back</a>
        </div>
    </div>
</div>

<% include ../partials/footer.ejs %>